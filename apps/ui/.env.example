# Base URL of the local DSP backend that exposes the canonical analysis-runs API
VITE_API_BASE_URL="http://127.0.0.1:8100"

# Optional Gemini phase-2 reconstruction pass (backend handles the API key).
# This stays on by default unless you use the env flag as a hard kill-switch.
VITE_ENABLE_PHASE2_GEMINI="true"

# Optional live Playwright proof for the real Gemini Files API path
RUN_GEMINI_LIVE_SMOKE="false"

# Optional dev-server knob for environments that need HMR disabled
DISABLE_HMR="false"
