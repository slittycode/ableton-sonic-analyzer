{
  "_meta": {
    "version": "1.0.0",
    "source": "Ableton Reference Manual Version 12 (ableton.com/en/manual/)",
    "scope": "ASA Phase 2 output surface only — curated subset, not an exhaustive model of every device parameter.",
    "policy": "NATIVE + MAX_FOR_LIVE only. No third-party VST/AU.",
    "live12_naming_notes": [
      "Auto Pan was renamed to Auto Pan-Tremolo in Live 12 (Chapter 28.3).",
      "Chorus was merged into Chorus-Ensemble in Live 11+. Do not emit 'Chorus' alone.",
      "Auto Shift is new in Live 12 (Chapter 28.4).",
      "Roar is Live 12 Standard only — excluded from ASA catalog (not available in all editions).",
      "Meld is new in Live 12 — macro-oscillator instrument.",
      "Drift is new in Live 12 — subtractive MPE instrument.",
      "Granulator III is the Live 12 version (M4L) — do not emit 'Granulator II'.",
      "Drum Sampler is new in Live 12 — single-pad sampler inside Drum Rack.",
      "EQ Eight is the canonical spelling — not 'EQ8' or 'EQ 8'.",
      "Glue Compressor is the canonical spelling — not 'Glue Comp'.",
      "Multiband Dynamics is the canonical spelling — not 'MultibandDynamics'."
    ]
  },
